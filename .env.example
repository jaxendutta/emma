# PubMed API (from A1/A2 — optional, for live AMG-RAG retrieval)
NCBI_EMAIL=your-email@uottawa.ca
NCBI_API_KEY=your-key-here

# Paths (override if your data lives elsewhere)
DATA_DIR=./data
MODELS_DIR=./models

# GitHub (for cloning the repo and pushing changes)
GITHUB_REPO_URL=https://github.com/jaxendutta/emma.git

# Ollama (local — no key needed, just make sure ollama is running)
OLLAMA_BASE_URL=http://localhost:11434
